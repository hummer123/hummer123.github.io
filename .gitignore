# ============================================================================
# Hugo 构建产物
# ============================================================================
# public/ 是 `hugo` 生成的静态站点，应由部署流水线（CI / gh-pages 分支）
# 产出，不应纳入源码版本控制。
/public/
/resources/
/.hugo_build.lock

# 本地配置覆盖（hugo --config 默认会同时加载 hugo.toml 和 hugo.local.toml）
hugo.local.toml

